% TEST_MATERIAL.m
% Run Bayesian model selection for IMR analysis
clear; clc; close all;

%% ========== CONFIGURATION ==========
material_id = 0;        % 0=synthetic, 1-9=experimental
use_parallel = false;   % Use parallel processing
num_workers = 32;       % Number of parallel workers
save_figures = true;    % Save figures
save_results = true;    % Save results
output_dir = './results';

% Models to test
models = {'newt', 'nh', 'kv', 'qnh', 'lm', 'qkv', 'sls'};

% GPR options
gprOpts = struct();
gprOpts.maxRounds = 25;
gprOpts.maxAddedMult = 120;
gprOpts.tolRelCI = 0.05;
gprOpts.betaGrid = 0.05:0.05:10;

%% ========== SETUP ==========
if save_figures || save_results
    if ~exist(output_dir, 'dir')
        mkdir(output_dir);
    end
end

% Start parallel pool if requested
if use_parallel
    delete(gcp('nocreate'));
    parpool(num_workers);
end

%% ========== RUN ANALYSIS ==========
fprintf('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n');
fprintf(  'в•‘   BAYESIAN MODEL SELECTION - MATERIAL %d       в•‘\n', material_id);
fprintf(  'в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n');
fprintf('Configuration:\n');
fprintf('  Material ID: %d\n', material_id);
fprintf('  Models: %s\n', strjoin(upper(models), ', '));
fprintf('  Parallel: %s (%d workers)\n', mat2str(use_parallel), num_workers);
fprintf('  Output: %s\n\n', output_dir);

try
    results = run_bayesian_imr(material_id, ...
        'models', models, ...
        'parallel', use_parallel, ...
        'gprOpts', gprOpts, ...
        'verbose', true, ...
        'saveFigs', save_figures, ...
        'saveResults', save_results, ...
        'outputDir', output_dir);
    
    % Print summary
    fprintf('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n');
    fprintf(  'в•‘ вњ“ ANALYSIS COMPLETE  в•‘\n');
    fprintf(  'в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n');
    fprintf('Best Model: %s\n', upper(results.best_model));
    fprintf('Posterior: P(M|D) = %.4f\n', results.max_posterior);
    fprintf('MAP Parameters: ');
    fprintf('%.4g ', results.theta_MAP{results.best_idx});
    fprintf('\n');
    fprintf('Total Time: %.1f seconds (%.1f minutes)\n\n', ...
            results.elapsed_time, results.elapsed_time/60);
    
    if save_results
        fprintf('Results saved to: %s\n\n', output_dir);
    end
    
catch ME
    fprintf('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\n');
    fprintf(  'в•‘ Г— ANALYSIS FAILED    в•‘\n');
    fprintf(  'в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n');
    fprintf('Error: %s\n', ME.message);
    fprintf('Location: %s (line %d)\n\n', ME.stack(1).name, ME.stack(1).line);
    rethrow(ME);
end